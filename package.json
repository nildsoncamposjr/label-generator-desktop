{
  "name": "gerador-etiquetas",
  "version": "1.4.6",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.seuprojeto.etiquetas",
    "productName": "Gerador de Etiquetas",
 
    "asar": false,

    "files": [
      "**/*",
      "fonts/**/*"
    ],

    "win": {
      "target": "nsis"
    },

    "directories": {
      "output": "dist"
    }
  },
  "devDependencies": {
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1"
  }
}
